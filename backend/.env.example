# Copy to .env and adjust for your machine.

# SQLite (default local dev)
DATABASE_URL=sqlite:///./sound_lab.db

# PostgreSQL (Render: use Internal Database URL from soundjbeats-db)
# DATABASE_URL=postgresql://user:password@hostname/dbname

# Comma-separated browser origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT signing secret — change in production
SECRET_KEY=supersecretkey_change_me

# Persistent uploads/exports (Render disk mount path in production)
# STORAGE_DIR=/opt/render/project/src/storage
